# ──────────────────────────────────────────────
# COPIA ESTE ARCHIVO A .env Y RELLENA LOS VALORES
# ──────────────────────────────────────────────

# MongoDB Atlas — GRATIS en mongodb.com/atlas (sin tarjeta de crédito)
# Crea un cluster M0, ve a "Connect" > "Drivers" y copia la URI
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/barbershop?retryWrites=true&w=majority

# Groq API — GRATIS en console.groq.com (sin tarjeta de crédito)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Telegram Bot — GRATIS con @BotFather en Telegram
# Deja vacío si no quieres usar Telegram por ahora
TELEGRAM_BOT_TOKEN=

# Servidor web
PORT=3000

# ── CONFIGURACIÓN DE LA PELUQUERÍA ────────────
SHOP_NAME=Barbería El Maestro
ASSISTANT_NAME=Alex
SHOP_PHONE=+34 600 000 000
SHOP_ADDRESS=Calle Mayor 12, Madrid

# Horario (formato HH:MM)
BUSINESS_HOURS_START=10:00
BUSINESS_HOURS_END=20:00

# Días laborables (0=Dom, 1=Lun, ..., 6=Sáb)
WORKING_DAYS=1,2,3,4,5,6

# Intervalo mínimo entre slots (minutos)
SLOT_INTERVAL=30

# Máximo de mensajes de historial que ve la IA
MAX_HISTORY_MESSAGES=20
