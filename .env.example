# ══════════════════════════════════════════════════════════════
# SECRETARIO IA — Variables de Entorno
# Copia este archivo a .env y rellena los valores
# ══════════════════════════════════════════════════════════════

# ── SERVIDOR ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── OPENAI API ────────────────────────────────────────────────
# Obtén tu key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ── POSTGRESQL (BASE DE DATOS) ────────────────────────────────
# Render PostgreSQL (se configura automáticamente en producción)
# Para desarrollo local: instala PostgreSQL y crea una base de datos
DATABASE_URL=postgresql://usuario:password@localhost:5432/secretario_ia

# ── JWT (AUTENTICACIÓN) ───────────────────────────────────────
# Genera un secreto aleatorio: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio_en_produccion

# ── STRIPE (PAGOS) ────────────────────────────────────────────
# Obtén tus keys en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# ID del precio de tu producto de suscripción mensual en Stripe
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# ── EMAIL (RESEND) ────────────────────────────────────────────
# Obtén tu key en: https://resend.com/api-keys (plan gratuito disponible)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@tudominio.com
FROM_NAME=Secretario IA

# ── APP ───────────────────────────────────────────────────────
APP_URL=https://tu-app.onrender.com

# ── CORS ──────────────────────────────────────────────────────
# Lista separada por comas de orígenes permitidos
# ALLOWED_ORIGINS=https://tu-frontend.com,https://localhost:3000
